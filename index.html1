<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wsparcie Techniczne AZS – Systemy Bezpieczeństwa</title>
    <!-- Google Fonts dla profesjonalnej typografii -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <!-- Ikony (Font Awesome dla prostoty) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f0f4f8 0%, #e6ecf4 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            line-height: 1.5;
            color: #1e293b;
        }

        .chat-card {
            width: 100%;
            max-width: 1100px;
            height: 90vh;
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: all 0.2s ease;
        }

        /* Шапка */
        .chat-header {
            background: #0b2b4f;
            padding: 20px 28px;
            color: white;
        }

        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand i {
            font-size: 28px;
            color: #60a5fa;
        }

        .brand h1 {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.02em;
        }

        .status-badge {
            background: #1e4a76;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 500;
            color: white;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-badge i {
            font-size: 10px;
            color: #4ade80;
        }

        .header-sub {
            font-size: 0.95rem;
            opacity: 0.9;
            margin-bottom: 16px;
        }

        .system-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .tag {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 500;
            color: white;
            transition: background 0.2s;
        }

        .tag:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Основная область сообщений */
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
            background: #f8fafc;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Сообщения */
        .message {
            max-width: 75%;
            padding: 14px 18px;
            border-radius: 22px;
            font-size: 0.95rem;
            line-height: 1.5;
            word-wrap: break-word;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.03);
            animation: fadeInUp 0.2s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.user {
            align-self: flex-end;
            background: #0b2b4f;
            color: white;
            border-bottom-right-radius: 4px;
        }

        .message.bot {
            align-self: flex-start;
            background: #ffffff;
            color: #1e293b;
            border: 1px solid #e2e8f0;
            border-bottom-left-radius: 4px;
        }

        .message.bot.typing {
            background: #e9eef2;
            color: #64748b;
            font-style: italic;
            border: 1px dashed #cbd5e1;
        }

        .message.error {
            background: #fee2e2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        /* Нижняя панель */
        .chat-footer {
            background: #ffffff;
            border-top: 1px solid #e2e8f0;
            padding: 20px 28px;
        }

        .input-wrapper {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
        }

        #message-input {
            flex: 1;
            padding: 16px 20px;
            border: 1px solid #cbd5e1;
            border-radius: 40px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: #f9fbfd;
        }

        #message-input:focus {
            border-color: #0b2b4f;
            box-shadow: 0 0 0 4px rgba(11, 43, 79, 0.1);
        }

        #message-input:disabled {
            background: #f1f5f9;
            color: #94a3b8;
            cursor: not-allowed;
        }

        #send-button {
            width: 56px;
            height: 56px;
            background: #0b2b4f;
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 1.4rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s, transform 0.1s;
            box-shadow: 0 8px 16px -4px rgba(11, 43, 79, 0.2);
        }

        #send-button:hover:not(:disabled) {
            background: #1e4a76;
            transform: scale(1.05);
        }

        #send-button:disabled {
            background: #94a3b8;
            cursor: not-allowed;
            box-shadow: none;
        }

        .examples {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .example-btn {
            background: #f1f5f9;
            border: 1px solid #cbd5e1;
            border-radius: 30px;
            padding: 10px 18px;
            font-size: 0.9rem;
            font-weight: 500;
            color: #1e293b;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .example-btn i {
            font-size: 0.8rem;
            color: #64748b;
        }

        .example-btn:hover {
            background: #e2e8f0;
            border-color: #94a3b8;
        }

        .footer-note {
            margin-top: 16px;
            font-size: 0.8rem;
            color: #64748b;
            text-align: center;
            border-top: 1px dashed #cbd5e1;
            padding-top: 16px;
        }

        /* Адаптивность */
        @media (max-width: 640px) {
            .chat-card {
                height: 100vh;
                border-radius: 0;
            }
            .chat-header {
                padding: 16px 20px;
            }
            .chat-messages {
                padding: 20px;
            }
            .chat-footer {
                padding: 16px 20px;
            }
            .brand h1 {
                font-size: 1.3rem;
            }
            .message {
                max-width: 85%;
            }
        }
    </style>
</head>
<body>
    <div class="chat-card">
        <!-- Шапка -->
        <div class="chat-header">
            <div class="header-top">
                <div class="brand">
                    <i class="fas fa-shield-alt"></i>
                    <h1>Wsparcie AZS</h1>
                </div>
                <div class="status-badge" id="status-badge">
                    <i class="fas fa-circle"></i>
                    <span>Inicjalizacja...</span>
                </div>
            </div>
            <div class="header-sub">
                <i class="fas fa-headset" style="margin-right: 8px;"></i>
                Inżynieria wsparcia • Systemy bezpieczeństwa
            </div>
            <div class="system-tags" id="system-tags">
                <!-- Теги будут добавлены через JS -->
            </div>
        </div>

        <!-- Область сообщений -->
        <div class="chat-messages" id="chat-messages"></div>

        <!-- Нижняя панель -->
        <div class="chat-footer">
            <div class="input-wrapper">
                <input type="text" id="message-input" placeholder="Opisz problem... (np. 'kamera nie działa')" autocomplete="off" disabled>
                <button id="send-button" disabled><i class="fas fa-paper-plane"></i></button>
            </div>
            <div class="examples" id="example-buttons"></div>
            <div class="footer-note">
                <i class="far fa-comment-dots" style="margin-right: 6px;"></i>
                Odpowiadamy tylko po polsku. Wpisz pytanie lub wybierz przykład.
            </div>
        </div>
    </div>

    <script>
        (function() {
            'use strict';

            // --- Konfiguracja ---
            const API_URL = 'https://assistics.up.railway.app/chat'; // ← Twój backend
            const sessionId = 'sesja_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);

            // Lista obsługiwanych systemów (dla badgeów)
            const SUPPORTED_SYSTEMS = [
                'Bosch', 'Hikvision', 'Paradox', 'Satel', 'Rosslare',
                '3xLogic', 'Provision', 'Siemens', 'Babyware'
            ];

            // Przykładowe pytania (dostosowane do rzeczywistych problemów)
            const EXAMPLES = [
                'Kamera nie wyświetla obrazu',
                'Jak zmienić kod w Rosslare?',
                'Alarm ciągle się włącza',
                'Nie mogę uzbroić systemu Paradox',
                'Brak nagrań z kamery Hikvision',
                'Czytnik kart nie reaguje',
                'Zmiana kodu użytkownika w Satel'
            ];

            // --- Elementy DOM ---
            const messagesDiv = document.getElementById('chat-messages');
            const input = document.getElementById('message-input');
            const sendButton = document.getElementById('send-button');
            const statusBadge = document.getElementById('status-badge');
            const systemTags = document.getElementById('system-tags');
            const examplesContainer = document.getElementById('example-buttons');

            // --- Stan ---
            let isSending = false;
            let puterReady = true; // Backend Groq zawsze gotowy, nie potrzebuje Puter.js

            // --- Funkcje pomocnicze ---
            function updateStatus(text, type = 'normal') {
                statusBadge.innerHTML = `<i class="fas fa-circle" style="color: ${type === 'error' ? '#f87171' : '#4ade80'};"></i> <span>${text}</span>`;
            }

            function addMessage(text, sender, isError = false) {
                const msgDiv = document.createElement('div');
                msgDiv.className = `message ${sender}${isError ? ' error' : ''}`;
                msgDiv.textContent = text;
                messagesDiv.appendChild(msgDiv);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
                return msgDiv;
            }

            function showTypingIndicator() {
                const typingDiv = document.createElement('div');
                typingDiv.id = 'typing-indicator';
                typingDiv.className = 'message bot typing';
                typingDiv.innerHTML = '<i class="fas fa-ellipsis-h" style="margin-right: 8px;"></i> Asystent pisze...';
                messagesDiv.appendChild(typingDiv);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            function removeTypingIndicator() {
                const typing = document.getElementById('typing-indicator');
                if (typing) typing.remove();
            }

            // --- Отправка сообщения ---
            async function sendMessage(text) {
                if (isSending || !text.trim()) return;

                isSending = true;
                input.disabled = true;
                sendButton.disabled = true;

                addMessage(text, 'user');
                input.value = '';
                showTypingIndicator();

                try {
                    const response = await fetch(API_URL, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            message: text,
                            session_id: sessionId
                        }),
                    });

                    removeTypingIndicator();

                    if (!response.ok) {
                        // Если 429 (rate limit) – покажем понятное сообщение
                        if (response.status === 429) {
                            addMessage('Osiągnięto limit zapytań. Proszę odczekać chwilę i spróbować ponownie.', 'bot', true);
                        } else {
                            throw new Error(`HTTP ${response.status}`);
                        }
                    } else {
                        const data = await response.json();
                        if (data.reply) {
                            addMessage(data.reply, 'bot');
                        } else {
                            addMessage('Przepraszam, nie otrzymałem poprawnej odpowiedzi.', 'bot', true);
                        }
                    }
                } catch (error) {
                    console.error('Błąd połączenia:', error);
                    removeTypingIndicator();
                    addMessage('❌ Błąd połączenia. Sprawdź sieć i spróbuj ponownie.', 'bot', true);
                } finally {
                    isSending = false;
                    input.disabled = false;
                    sendButton.disabled = false;
                    input.focus();
                }
            }

            // --- Инициализация интерфейса ---
            function initUI() {
                // Добавляем бейджи с системами
                SUPPORTED_SYSTEMS.forEach(sys => {
                    const tag = document.createElement('span');
                    tag.className = 'tag';
                    tag.textContent = sys;
                    systemTags.appendChild(tag);
                });

                // Добавляем приветственное сообщение
                addMessage(
                    'Cześć! 👋 Jestem inżynierem wsparcia technicznego. Opisz swój problem związany z monitoringiem, alarmem lub kontrolą dostępu. Postaram się pomóc.',
                    'bot'
                );

                // Добавляем кнопки с примерами
                EXAMPLES.forEach(ex => {
                    const btn = document.createElement('button');
                    btn.className = 'example-btn';
                    btn.innerHTML = `<i class="fas fa-search"></i> ${ex}`;
                    btn.addEventListener('click', () => {
                        input.value = ex;
                        sendMessage(ex);
                    });
                    examplesContainer.appendChild(btn);
                });

                // Активируем интерфейс
                input.disabled = false;
                sendButton.disabled = false;
                input.focus();
                updateStatus('Gotowy');
            }

            // Запускаем инициализацию после полной загрузки DOM
            window.addEventListener('DOMContentLoaded', initUI);
        })();
    </script>
</body>
</html>
